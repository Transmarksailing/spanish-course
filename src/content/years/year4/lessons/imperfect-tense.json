    {
      "type": "rule_box",
      "title": { "en": "Irregular Imperfect Verbs", "nl": "Onregelmatige Imperfecto Werkwoorden" },
      "content": {
        "en": "Only **three verbs** are irregular in the imperfect:\n\n**ir**: iba, ibas, iba, íbamos, ibais, iban\n**ser**: era, eras, era, éramos, erais, eran\n**ver**: veía, veías, veía, veíamos, veíais, veían",
        "nl": "Slechts **drie werkwoorden** zijn onregelmatig in het imperfecto:\n\n**ir**: iba, ibas, iba, íbamos, ibais, iban\n**ser**: era, eras, era, éramos, erais, eran\n**ver**: veía, veías, veía, veíamos, veíais, veían"
      }
    }
  ],

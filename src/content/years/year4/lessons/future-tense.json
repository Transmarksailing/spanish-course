  "grammarSections": [
    {
      "type": "explanation",
      "title": { "en": "IR A + Infinitive", "nl": "IR A + Infinitief" },
      "content": {
        "en": "The future can be expressed by using the verb **ir a** with an infinitive. This is the equivalent of the English 'to be going to'.\n\n**Voy a trabajar allí.** — I'm going to work there.\n**Vamos a comer en casa.** — We are going to eat at home.\n**Ellos van a vivir con nosotros.** — They are going to live with us.",
        "nl": "De toekomst kan uitgedrukt worden met het werkwoord **ir a** gevolgd door een infinitief. Dit is vergelijkbaar met het Nederlandse 'gaan + infinitief'.\n\n**Voy a trabajar allí.** — Ik ga daar werken.\n**Vamos a comer en casa.** — We gaan thuis eten.\n**Ellos van a vivir con nosotros.** — Zij gaan bij ons wonen."
      }
    },
    {
      "type": "conjugation_table",
      "title": { "en": "IR — Present Tense", "nl": "IR — Tegenwoordige Tijd" },
      "verb": "ir",
      "tense": "present",
      "forms": {
        "yo": "voy",
        "tú": "vas",
        "él/ella/usted": "va",
        "nosotros": "vamos",
        "vosotros": "vais",
        "ellos/ustedes": "van"
      }
    },
    {
      "type": "explanation",
      "title": { "en": "Simple Future Tense", "nl": "Onvoltooid Toekomende Tijd" },
      "content": {
        "en": "The future tense of regular verbs is formed by adding the following personal endings to the infinitive:\n**-é, -ás, -á, -emos, -éis, -án**\n\nThis is equivalent to 'will' in English.",
        "nl": "De onvoltooid toekomende tijd van regelmatige werkwoorden wordt gevormd door de volgende persoonlijke uitgangen aan het hele werkwoord toe te voegen:\n**-é, -ás, -á, -emos, -éis, -án**\n\nDit is vergelijkbaar met 'zullen' in het Nederlands."
      }
    },

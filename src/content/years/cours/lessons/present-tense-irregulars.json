        { "id": "pti-002", "sentence": "Yo ___ el trabajo. (comenzar)", "correctAnswers": ["comienzo"], "translation": { "en": "I start the work.", "nl": "Ik begin het werk." }, "hint": "o → ie in yo" },
        { "id": "pti-003", "sentence": "Yo no ___ hacer nada. (poder)", "correctAnswers": ["puedo"], "translation": { "en": "I can't do anything.", "nl": "Ik kan niets doen." }, "hint": "o → ue" },
        { "id": "pti-004", "sentence": "Ella ___ a las once. (volver)", "correctAnswers": ["vuelve"], "translation": { "en": "She returns at eleven.", "nl": "Zij komt om elf uur terug." }, "hint": "o → ue" },
        { "id": "pti-005", "sentence": "Nosotros no ___ salir. (querer)", "correctAnswers": ["queremos"], "translation": { "en": "We don't want to go out.", "nl": "Wij willen niet uitgaan." }, "hint": "nosotros = no stem change" },
        { "id": "pti-006", "sentence": "Nosotros ___ la puerta. (cerrar)", "correctAnswers": ["cerramos"], "translation": { "en": "We close the door.", "nl": "Wij sluiten de deur." }, "hint": "nosotros = no stem change" },
        { "id": "pti-007", "sentence": "Ellos ___ el juego. (perder)", "correctAnswers": ["pierden"], "translation": { "en": "They lose the game.", "nl": "Zij verliezen het spel." }, "hint": "e → ie" },
        { "id": "pti-008", "sentence": "¿Qué ___ tú? (pensar)", "correctAnswers": ["piensas"], "translation": { "en": "What do you think?", "nl": "Wat denk jij?" }, "hint": "e → ie" },
        { "id": "pti-009", "sentence": "Todo ___ mucho. (costar)", "correctAnswers": ["cuesta"], "translation": { "en": "Everything costs a lot.", "nl": "Alles kost veel." }, "hint": "o → ue" },
        { "id": "pti-010", "sentence": "¿Por qué no ___ tú en el parque? (jugar)", "correctAnswers": ["juegas"], "translation": { "en": "Why don't you play in the park?", "nl": "Waarom speel jij niet in het park?" }, "hint": "u → ue" },
        { "id": "pti-011", "sentence": "Yo ___ un bistec. (pedir)", "correctAnswers": ["pido"], "translation": { "en": "I order a steak.", "nl": "Ik bestel een biefstuk." }, "hint": "e → i" },
        { "id": "pti-012", "sentence": "El camarero ___ las bebidas. (servir)", "correctAnswers": ["sirve"], "translation": { "en": "The waiter serves the drinks.", "nl": "De ober serveert de drankjes." }, "hint": "e → i" },
        { "id": "pti-013", "sentence": "Nosotros ___ la lección. (repetir)", "correctAnswers": ["repetimos"], "translation": { "en": "We repeat the lesson.", "nl": "Wij herhalen de les." }, "hint": "nosotros = no stem change" },
        { "id": "pti-014", "sentence": "El niño siempre ___. (reír)", "correctAnswers": ["ríe"], "translation": { "en": "The child always laughs.", "nl": "Het kind lacht altijd." }, "hint": "e → í" },
        { "id": "pti-015", "sentence": "Mi hijo ___ coleccionar insectos. (querer)", "correctAnswers": ["quiere"], "translation": { "en": "My son wants to collect insects.", "nl": "Mijn zoon wil insecten verzamelen." }, "hint": "e → ie" },
        { "id": "pti-016", "sentence": "El bebé ___ en el carricoche. (dormir)", "correctAnswers": ["duerme"], "translation": { "en": "The baby sleeps in the stroller.", "nl": "De baby slaapt in de kinderwagen." }, "hint": "o → ue" },
        { "id": "pti-017", "sentence": "Ella ___ comer pan integral. (preferir)", "correctAnswers": ["prefiere"], "translation": { "en": "She prefers to eat whole grain bread.", "nl": "Zij geeft de voorkeur aan volkorenbrood eten." }, "hint": "e → ie" },

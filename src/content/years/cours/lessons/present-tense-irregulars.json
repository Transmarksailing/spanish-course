        { "id": "pti-019", "sentence": "Yo no ___ nada de la física. (entender)", "correctAnswers": ["entiendo"], "translation": { "en": "I don't understand anything about physics.", "nl": "Ik begrijp niets van natuurkunde." }, "hint": "e → ie" },
